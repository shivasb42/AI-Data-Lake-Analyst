# AWS region for S3, Glue, Athena, and Bedrock
AWS_REGION=us-east-1

# S3 data lake bucket (Parquet + FAISS index)
S3_DATA_BUCKET=your-datalake-bucket-name

# Athena query results location (must start with s3://)
S3_ATHENA_RESULTS=s3://your-athena-results-bucket/

# Glue catalog
GLUE_DATABASE=nyc_taxi
GLUE_TABLE=yellow_taxi

# Bedrock models (enable in console → Model access)
BEDROCK_CHAT_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Path to schema metadata JSON (used for embedding pipeline)
SCHEMA_PATH=yellow_taxi_schema.json

# S3 keys for vector index artifacts
FAISS_INDEX_KEY=faiss/faiss_index.bin
FAISS_METADATA_KEY=faiss/metadata_texts.json
